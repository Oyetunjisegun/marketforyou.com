# Copy to .env.local for local dev, and set these in the Vercel dashboard
# (Project Settings -> Environment Variables) for deploys.

# --- Supabase (required) ---
# Project URL and anon key are safe for the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key bypasses RLS. SERVER-ONLY — never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Site origin (required in production) ---
# Drives metadata base, JSON-LD, canonical URLs, and payment redirect URLs.
# Set to your production domain on Vercel, e.g. https://marketforyou.com
# Falls back to VERCEL_URL (auto-injected by Vercel) then localhost.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Flutterwave payments (required for checkout) ---
# Server secret key. Use the TEST key (sk_test_...) for sandbox. SERVER-ONLY.
FLW_SECRET_KEY=""
# The "secret hash" you configure in the Flutterwave dashboard webhook settings.
# The webhook route rejects any payload whose verif-hash header doesn't match.
FLW_SECRET_HASH=""

# --- Optional ---
# USD -> NGN conversion rate applied at checkout. Defaults to 1600 if unset.
NEXT_PUBLIC_USD_NGN_RATE="1600"
